// ───────────────────────────────────────────────────────────
// NexAI CRM — Base de datos principal (Postgres)
// ───────────────────────────────────────────────────────────

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  ADMIN
  CLIENTE
}

model Business {
  id           String             @id @default(uuid())
  nombre       String
  canales      String[] // ['whatsapp','instagram','messenger']
  activo       Boolean            @default(true)
  creadoAt     DateTime           @default(now())
  plan               String             @default("basico") // 'basico' | 'pro'
  tablaMemoria       String?
  modoClasificacion    String             @default("sugerencia") // 'sugerencia' | 'automatico'
  buscarMediaEvolution Boolean            @default(false) // Si true: escanear BD Evolution por imágenes del bot (WA)
  instancias   BusinessInstance[]
  usuarios     User[]
  mensajes     Message[]
  etapas       FunnelStage[]
  roles        BusinessRole[]
  campos       CustomField[]
  campanas     Campaign[]
  paymentConfig PaymentConfig?
  bugReports   BugReport[]

  @@map("businesses")
}

model BusinessInstance {
  id          String   @id @default(uuid())
  businessId  String
  business    Business @relation(fields: [businessId], references: [id], onDelete: Cascade)
  canal       String // 'whatsapp' | 'instagram' | 'messenger'
  instanciaId String // instance_name (WA) o entry[0].id (FB/IG)
  activo      Boolean  @default(true)
  creadoAt    DateTime @default(now())

  // Meta credentials (instagram | messenger only)
  metaPageId          String?   // Facebook Page ID (auto-derived on token save)
  metaPageAccessToken String?   // Page Access Token
  metaTokenSetAt      DateTime? // Last time token was saved
  metaTokenExpiresAt  DateTime? // null = permanent (Messenger); 60d = Instagram

  @@unique([canal, instanciaId])
  @@index([businessId])
  @@map("business_instances")
}

model User {
  id             String        @id @default(uuid())
  email          String        @unique
  password       String // bcrypt hash
  nombre         String
  rol            Role
  activo         Boolean       @default(true)
  businessId     String? // null si ADMIN
  business       Business?     @relation(fields: [businessId], references: [id], onDelete: SetNull)
  businessRoleId String?
  businessRole   BusinessRole? @relation(fields: [businessRoleId], references: [id], onDelete: SetNull)
  creadoAt       DateTime      @default(now())
  bugReports     BugReport[]

  @@index([businessId])
  @@map("users")
}

model Message {
  id            BigInt   @id @default(autoincrement())
  instanciaId   String
  businessId    String
  business      Business @relation(fields: [businessId], references: [id], onDelete: Cascade)
  nombreNegocio String
  canal         String
  uidUsuario    String
  rol           String // 'user' | 'bot' | 'human' | 'page'
  contenido     String?
  tipoMedia     String   @default("text")
  enviadoAt     DateTime @default(now())
  latenciaMs    Int?
  metadata      Json?

  @@index([businessId])
  @@index([instanciaId, uidUsuario])
  @@index([instanciaId, uidUsuario, enviadoAt])
  @@index([enviadoAt(sort: Desc)])
  @@map("messages")
}

model AuditLog {
  id          Int      @id @default(autoincrement())
  timestamp   DateTime @default(now())
  instanciaId String
  canal       String?
  uidUsuario  String?
  rol         String?
  contenido   String?
  status      String
  errorDetail String?
  messageId   String?

  @@index([timestamp(sort: Desc)])
  @@index([status])
  @@index([instanciaId])
  @@map("audit_logs")
}

model Contact {
  id          String              @id @default(uuid())
  uidUsuario  String
  instanciaId String
  canal       String
  nombre      String?
  username    String?
  fotoPerfil  String?
  resolvedAt  DateTime            @default(now())
  etapas      ContactStage[]
  notas       ContactNote[]
  etiquetas   ContactTag[]
  camposCustom ContactFieldValue[]

  // Sugerencia de etapa generada por IA (clasificador del embudo)
  sugerenciaStageId String?
  sugerenciaStage   FunnelStage?  @relation("sugerencia", fields: [sugerenciaStageId], references: [id], onDelete: SetNull)
  sugerenciaRazon   String?
  clasificadoAt     DateTime? // marca de última clasificación (throttle)
  followUpLogs      FollowUpLog[]

  @@unique([instanciaId, uidUsuario])
  @@index([sugerenciaStageId])
  @@map("contacts")
}

model IncidentLog {
  id               Int       @id @default(autoincrement())
  instanciaId      String
  nombreNegocio    String?
  tipo             String // 'caida_detectada'|'auto-recuperada'|'intervencion_manual'
  contactosSinResp Int
  estadoEvolution  String?
  accion           String?
  resultado        String?
  emailEnviado     Boolean   @default(false)
  creadoAt         DateTime  @default(now())
  resolvedAt       DateTime?

  @@index([instanciaId])
  @@index([creadoAt(sort: Desc)])
  @@map("incident_logs")
}

model FunnelStage {
  id                 String          @id @default(uuid())
  businessId         String
  business           Business        @relation(fields: [businessId], references: [id], onDelete: Cascade)
  nombre             String
  orden              Int
  color              String          @default("#6366F1")
  descripcion        String? // qué representa esta etapa (lo usa el clasificador IA)
  mensajeSeguimiento String?
  creadoAt           DateTime        @default(now())
  contactos          ContactStage[]
  sugeridoA          Contact[]       @relation("sugerencia")
  followUpConfig     FollowUpConfig?

  @@index([businessId])
  @@map("funnel_stages")
}

model ContactStage {
  id         String      @id @default(uuid())
  contactId  String
  contact    Contact     @relation(fields: [contactId], references: [id], onDelete: Cascade)
  stageId    String
  stage      FunnelStage @relation(fields: [stageId], references: [id], onDelete: Cascade)
  businessId String
  asignadoAt DateTime    @default(now())

  @@unique([contactId, businessId])
  @@map("contact_stages")
}

model FollowUpConfig {
  id                String      @id @default(uuid())
  stageId           String      @unique
  stage             FunnelStage @relation(fields: [stageId], references: [id], onDelete: Cascade)
  activo            Boolean     @default(false)
  modoEnvio         String      @default("manual") // 'automatico' | 'manual'
  tiempoInactividad Int         @default(120) // minutos
  maxEnviosPorDia   Int         @default(1)
  maxEnviosTotal    Int?        @default(3) // null = sin límite
  creadoAt          DateTime    @default(now())
  updatedAt         DateTime    @updatedAt

  @@map("follow_up_configs")
}

model FollowUpLog {
  id             String   @id @default(uuid())
  contactId      String
  contact        Contact  @relation(fields: [contactId], references: [id], onDelete: Cascade)
  stageId        String
  businessId     String
  canal          String
  uidUsuario     String
  instanciaId    String
  decision       String // 'enviado'|'omitido'|'ventana_cerrada'|'limite_alcanzado'|'ia_descarto'|'error'
  razonIA        String?
  mensajeEnviado String?
  etapaDetectada String?
  aprobado       Boolean?
  creadoAt       DateTime @default(now())

  @@index([contactId])
  @@index([businessId])
  @@index([creadoAt(sort: Desc)])
  @@map("follow_up_logs")
}

// ───────────────────────────────────────────────────────────
// FASE FINAL — Roles, Contactos enriquecidos, Campañas
// ───────────────────────────────────────────────────────────

model BusinessRole {
  id         String   @id @default(uuid())
  businessId String
  business   Business @relation(fields: [businessId], references: [id], onDelete: Cascade)
  nombre     String
  permisos   String[]
  creadoAt   DateTime @default(now())
  usuarios   User[]

  @@unique([businessId, nombre])
  @@map("business_roles")
}

model ContactNote {
  id         String   @id @default(uuid())
  contactId  String
  contact    Contact  @relation(fields: [contactId], references: [id], onDelete: Cascade)
  businessId String
  contenido  String
  creadoPor  String
  creadoAt   DateTime @default(now())

  @@index([contactId])
  @@map("contact_notes")
}

model ContactTag {
  id         String  @id @default(uuid())
  contactId  String
  contact    Contact @relation(fields: [contactId], references: [id], onDelete: Cascade)
  businessId String
  etiqueta   String

  @@unique([contactId, businessId, etiqueta])
  @@map("contact_tags")
}

model CustomField {
  id         String              @id @default(uuid())
  businessId String
  business   Business            @relation(fields: [businessId], references: [id], onDelete: Cascade)
  nombre     String
  tipo       String // 'texto'|'numero'|'fecha'|'select'
  opciones   String[]
  orden      Int                 @default(0)
  creadoAt   DateTime            @default(now())
  valores    ContactFieldValue[]

  @@index([businessId])
  @@map("custom_fields")
}

model ContactFieldValue {
  id        String      @id @default(uuid())
  contactId String
  contact   Contact     @relation(fields: [contactId], references: [id], onDelete: Cascade)
  fieldId   String
  field     CustomField @relation(fields: [fieldId], references: [id], onDelete: Cascade)
  valor     String

  @@unique([contactId, fieldId])
  @@map("contact_field_values")
}

model Campaign {
  id             String        @id @default(uuid())
  businessId     String
  business       Business      @relation(fields: [businessId], references: [id], onDelete: Cascade)
  nombre         String
  mensaje        String
  canal          String // 'whatsapp'|'instagram'|'messenger'
  estado         String        @default("borrador") // 'borrador'|'enviando'|'completada'|'cancelada'
  filtroEtapa    String?
  instanciaId    String?
  totalContactos Int           @default(0)
  enviados       Int           @default(0)
  fallidos       Int           @default(0)
  contactoActual Int           @default(0)
  procesando     Boolean       @default(false)
  delayMin       Int           @default(8)
  delayMax       Int           @default(20)
  riesgoAceptado Boolean       @default(false)
  tipoMensaje    String        @default("texto") // 'texto'|'imagen'|'documento'
  mediaUrl       String? // URL pública de Cloudinary (imagen o documento)
  mediaCaption   String? // texto que acompaña la imagen/documento
  creadoAt       DateTime      @default(now())
  iniciadoAt     DateTime?
  completadoAt   DateTime?
  logs           CampaignLog[]

  @@index([businessId])
  @@index([estado])
  @@map("campaigns")
}

model CampaignLog {
  id         String   @id @default(uuid())
  campaignId String
  campaign   Campaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  uidUsuario String
  estado     String // 'enviado'|'fallido'
  error      String?
  enviadoAt  DateTime @default(now())

  @@index([campaignId])
  @@map("campaign_logs")
}

// Registro de ejecuciones del scheduler interno (node-cron). El id es el nombre
// del job: 'health-check'|'follow-up'|'weekly-summary'|'campaigns'.
// ultimaEjecucion también actúa como lock de claim atómico anti-doble-ejecución.
model CronExecution {
  id              String    @id
  ultimaEjecucion DateTime?
  ultimoEstado    String? // 'ok'|'error'
  ultimoResultado String? // JSON del resultado

  @@map("cron_executions")
}

// ───────────────────────────────────────────────────────────
// Pagos y cobros
// ───────────────────────────────────────────────────────────

model PaymentConfig {
  id           String    @id @default(uuid())
  businessId   String    @unique
  business     Business  @relation(fields: [businessId], references: [id], onDelete: Cascade)
  montoMensual Float
  diasGracia   Int       @default(7)
  proximoPago  DateTime
  activo       Boolean   @default(true)
  suspendido   Boolean   @default(false)
  suspendidoAt DateTime?
  creadoAt     DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  pagos        Payment[]

  @@map("payment_configs")
}

model Payment {
  id            String        @id @default(uuid())
  configId      String
  config        PaymentConfig @relation(fields: [configId], references: [id], onDelete: Cascade)
  businessId    String
  monto         Float
  periodo       String
  fechaPago     DateTime
  fechaVencia   DateTime
  registradoPor String
  notas         String?
  creadoAt      DateTime      @default(now())

  @@unique([configId, periodo])
  @@index([businessId])
  @@index([configId])
  @@map("payments")
}

model PaymentNotification {
  id         String   @id @default(uuid())
  businessId String
  tipo       String
  // 'aviso_7d'|'aviso_3d'|'aviso_1d'|'dia_vencimiento'
  // 'mora_1d'|'mora_3d'|'suspendido'|'pago_confirmado'
  enviadoAt  DateTime @default(now())
  exitoso    Boolean  @default(true)

  @@index([businessId])
  @@index([enviadoAt(sort: Desc)])
  @@map("payment_notifications")
}

// ───────────────────────────────────────────────────────────
// Seguimiento de reportes de bugs
// ───────────────────────────────────────────────────────────

model BugReport {
  id            String          @id @default(cuid())
  businessId    String
  business      Business        @relation(fields: [businessId], references: [id], onDelete: Cascade)
  userId        String?
  user          User?           @relation(fields: [userId], references: [id], onDelete: SetNull)
  nombreReporta String // nombre de quien reportó (por si no hay user)
  emailReporta  String?
  descripcion   String          @db.Text
  pagina        String? // URL o sección donde ocurrió
  screenshot    String? // URL de Cloudinary si se adjunta
  estado        String          @default("abierto") // abierto | en_progreso | resuelto | descartado
  prioridad     String          @default("media") // baja | media | alta | critica
  creadoEn      DateTime        @default(now())
  actualizadoEn DateTime        @updatedAt
  resueltoEn    DateTime?
  notas         BugReportNote[]

  @@index([businessId, estado])
  @@index([estado, prioridad])
  @@map("bug_reports")
}

model BugReportNote {
  id          String    @id @default(cuid())
  bugReportId String
  bugReport   BugReport @relation(fields: [bugReportId], references: [id], onDelete: Cascade)
  contenido   String    @db.Text
  creadoEn    DateTime  @default(now())

  @@map("bug_report_notes")
}
