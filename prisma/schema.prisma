// ───────────────────────────────────────────────────────────
// NexAI CRM — Base de datos principal (Postgres)
// ───────────────────────────────────────────────────────────

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  ADMIN
  CLIENTE
}

model Business {
  id           String             @id @default(uuid())
  nombre       String
  canales      String[] // ['whatsapp','instagram','messenger']
  activo       Boolean            @default(true)
  creadoAt     DateTime           @default(now())
  plan         String             @default("basico") // 'basico' | 'pro'
  tablaMemoria String?
  instancias   BusinessInstance[]
  usuarios     User[]
  mensajes     Message[]
  etapas       FunnelStage[]

  @@map("businesses")
}

model BusinessInstance {
  id          String   @id @default(uuid())
  businessId  String
  business    Business @relation(fields: [businessId], references: [id], onDelete: Cascade)
  canal       String // 'whatsapp' | 'instagram' | 'messenger'
  instanciaId String // instance_name (WA) o entry[0].id (FB/IG)
  activo      Boolean  @default(true)
  creadoAt    DateTime @default(now())

  // Meta credentials (instagram | messenger only)
  metaPageId          String?   // Facebook Page ID (auto-derived on token save)
  metaPageAccessToken String?   // Page Access Token
  metaTokenSetAt      DateTime? // Last time token was saved
  metaTokenExpiresAt  DateTime? // null = permanent (Messenger); 60d = Instagram

  @@unique([canal, instanciaId])
  @@index([businessId])
  @@map("business_instances")
}

model User {
  id         String    @id @default(uuid())
  email      String    @unique
  password   String // bcrypt hash
  nombre     String
  rol        Role
  activo     Boolean   @default(true)
  businessId String? // null si ADMIN
  business   Business? @relation(fields: [businessId], references: [id], onDelete: SetNull)
  creadoAt   DateTime  @default(now())

  @@index([businessId])
  @@map("users")
}

model Message {
  id            BigInt   @id @default(autoincrement())
  instanciaId   String
  businessId    String
  business      Business @relation(fields: [businessId], references: [id], onDelete: Cascade)
  nombreNegocio String
  canal         String
  uidUsuario    String
  rol           String // 'user' | 'bot' | 'human' | 'page'
  contenido     String?
  tipoMedia     String   @default("text")
  enviadoAt     DateTime @default(now())
  latenciaMs    Int?
  metadata      Json?

  @@index([businessId])
  @@index([instanciaId, uidUsuario])
  @@index([enviadoAt(sort: Desc)])
  @@map("messages")
}

model AuditLog {
  id          Int      @id @default(autoincrement())
  timestamp   DateTime @default(now())
  instanciaId String
  canal       String?
  uidUsuario  String?
  rol         String?
  contenido   String?
  status      String
  errorDetail String?
  messageId   String?

  @@index([timestamp(sort: Desc)])
  @@index([status])
  @@index([instanciaId])
  @@map("audit_logs")
}

model Contact {
  id          String         @id @default(uuid())
  uidUsuario  String
  instanciaId String
  canal       String
  nombre      String?
  username    String?
  fotoPerfil  String?
  resolvedAt  DateTime       @default(now())
  etapas      ContactStage[]

  // Sugerencia de etapa generada por IA (clasificador del embudo)
  sugerenciaStageId String?
  sugerenciaStage   FunnelStage?  @relation("sugerencia", fields: [sugerenciaStageId], references: [id], onDelete: SetNull)
  sugerenciaRazon   String?
  clasificadoAt     DateTime? // marca de última clasificación (throttle)
  followUpLogs      FollowUpLog[]

  @@unique([instanciaId, uidUsuario])
  @@index([sugerenciaStageId])
  @@map("contacts")
}

model IncidentLog {
  id               Int       @id @default(autoincrement())
  instanciaId      String
  nombreNegocio    String?
  tipo             String // 'caida_detectada'|'auto-recuperada'|'intervencion_manual'
  contactosSinResp Int
  estadoEvolution  String?
  accion           String?
  resultado        String?
  emailEnviado     Boolean   @default(false)
  creadoAt         DateTime  @default(now())
  resolvedAt       DateTime?

  @@index([instanciaId])
  @@index([creadoAt(sort: Desc)])
  @@map("incident_logs")
}

model FunnelStage {
  id                 String          @id @default(uuid())
  businessId         String
  business           Business        @relation(fields: [businessId], references: [id], onDelete: Cascade)
  nombre             String
  orden              Int
  color              String          @default("#6366F1")
  descripcion        String? // qué representa esta etapa (lo usa el clasificador IA)
  mensajeSeguimiento String?
  creadoAt           DateTime        @default(now())
  contactos          ContactStage[]
  sugeridoA          Contact[]       @relation("sugerencia")
  followUpConfig     FollowUpConfig?

  @@index([businessId])
  @@map("funnel_stages")
}

model ContactStage {
  id         String      @id @default(uuid())
  contactId  String
  contact    Contact     @relation(fields: [contactId], references: [id], onDelete: Cascade)
  stageId    String
  stage      FunnelStage @relation(fields: [stageId], references: [id], onDelete: Cascade)
  businessId String
  asignadoAt DateTime    @default(now())

  @@unique([contactId, businessId])
  @@map("contact_stages")
}

model FollowUpConfig {
  id                String      @id @default(uuid())
  stageId           String      @unique
  stage             FunnelStage @relation(fields: [stageId], references: [id], onDelete: Cascade)
  activo            Boolean     @default(false)
  modoEnvio         String      @default("manual") // 'automatico' | 'manual'
  tiempoInactividad Int         @default(120) // minutos
  maxEnviosPorDia   Int         @default(1)
  maxEnviosTotal    Int?        @default(3) // null = sin límite
  creadoAt          DateTime    @default(now())
  updatedAt         DateTime    @updatedAt

  @@map("follow_up_configs")
}

model FollowUpLog {
  id             String   @id @default(uuid())
  contactId      String
  contact        Contact  @relation(fields: [contactId], references: [id], onDelete: Cascade)
  stageId        String
  businessId     String
  canal          String
  uidUsuario     String
  instanciaId    String
  decision       String // 'enviado'|'omitido'|'ventana_cerrada'|'limite_alcanzado'|'ia_descarto'|'error'
  razonIA        String?
  mensajeEnviado String?
  etapaDetectada String?
  aprobado       Boolean?
  creadoAt       DateTime @default(now())

  @@index([contactId])
  @@index([businessId])
  @@index([creadoAt(sort: Desc)])
  @@map("follow_up_logs")
}
