# ╔══════════════════════════════════════════════════════════════╗
# ║                    NexAI CRM · .env.example                   ║
# ║   Copia este archivo a .env y reemplaza los <...> por tus     ║
# ║   valores. En EasyPanel pega esto en la pestaña Environment.  ║
# ╚══════════════════════════════════════════════════════════════╝

# ─── Base de datos del CRM (Prisma) ──────────────────────────────
# Negocios, usuarios, instancias y mensajes.
DATABASE_URL=postgresql://USER:PASSWORD@HOST:PORT/crm

# ─── Base de datos de n8n (solo tabla ESTATUS, vía pg) ───────────
# El CRM SOLO lee/escribe la tabla ESTATUS. Nunca se migra su esquema.
N8N_DATABASE_URL=postgresql://USER:PASSWORD@HOST:PORT/postgres

# ─── Base de datos de Evolution API (multimedia del bot, vía pg) ─
# Solo lectura: el CRM busca aquí imágenes enviadas por el bot WA.
# Requiere Business.buscarMediaEvolution = true en el panel admin.
# Host interno en EasyPanel: evolution_api_evolution-api-db:5432
EVOLUTION_DB_URL=""

# ─── Autenticación (NextAuth v5) ─────────────────────────────────
# AUTH_SECRET y NEXTAUTH_SECRET deben tener el MISMO valor.
# Genera uno con:  openssl rand -base64 32   (o  npx auth secret)
AUTH_SECRET=<genera-un-secreto-de-32-bytes>
NEXTAUTH_SECRET=<el-mismo-valor-que-AUTH_SECRET>
# Necesario detrás del proxy de EasyPanel.
AUTH_TRUST_HOST=true

# ─── URLs públicas (runtime · sin build-args) ────────────────────
# Dominio del CRM. Si usas dominio propio, cámbialo aquí (sin rebuild).
NEXTAUTH_URL=https://postgres-nexcrm.d6cr6o.easypanel.host
# URL que muestran los snippets de n8n (default = NEXTAUTH_URL).
APP_URL=https://postgres-nexcrm.d6cr6o.easypanel.host

# ─── Seguridad del endpoint de ingesta (recomendado) ─────────────
# Si se define, POST /api/messages exige:  Authorization: Bearer <token>
MESSAGES_INGEST_TOKEN=<token-aleatorio>

# ─── Evolution API (respuestas humanas por WhatsApp) ─────────────
# Si no se definen, las respuestas se registran en el CRM pero NO se envían.
# En EasyPanel usa el host interno del servicio (más rápido y sin salir a internet):
#   EVOLUTION_API_URL=http://evolution-api-evolution-api:8080
EVOLUTION_API_URL=http://evolution-api-evolution-api:8080
EVOLUTION_API_KEY=<AUTHENTICATION_API_KEY-de-evolution>

# ─── Cloudinary (adjuntos multimedia en respuestas humanas) ──────
# Necesario para enviar imágenes/audio/video/documentos desde el CRM.
# Sin esto, POST /api/upload falla y solo se puede responder con texto.
CLOUDINARY_CLOUD_NAME=<cloud-name>
CLOUDINARY_API_KEY=<api-key>
CLOUDINARY_API_SECRET=<api-secret>

# ─── Credenciales Meta (Instagram / Messenger) ───────────────────
# NO van en .env: se guardan por instancia desde el panel admin
# (Negocios → [negocio] → Credenciales Meta). El token se valida contra
# graph.instagram.com (IG, token IGAA…) o graph.facebook.com (Messenger,
# token EAAW…) según el canal. Ver src/lib/meta.ts.

# ─── OpenAI (resúmenes con IA) ───────────────────────────────────
# Necesario para POST /api/summary. Modelo: gpt-5.4-mini.
OPENAI_API_KEY=<sk-proj-...>

# Tope de clasificaciones IA del embudo por negocio por día (default 300).
# Soft cap en memoria de proceso: se reinicia con cada deploy/restart.
# Solo cuentan llamadas exitosas; aplica también al botón manual.
# FUNNEL_AI_DAILY_CAP=300

# ─── Resend (alertas de salud por email) ─────────────────────────
# Necesario para el monitor de salud (/api/cron/health-check).
RESEND_API_KEY=<re_...>
RESEND_FROM=<ej: alertas@nexai.mx>
NEXAI_ALERT_EMAIL=<ej: admin@miempresa.com>

# ─── Cron (monitor de salud) ─────────────────────────────────────
# Token para proteger GET /api/cron/health-check.
# Genera uno con:  openssl rand -base64 32
# Configura el cron en cron-job.org:
#   URL: https://postgres-nexcrm.d6cr6o.easypanel.host/api/cron/health-check
#   Método: GET · Header: Authorization: Bearer <CRON_SECRET> · Cada 5 minutos
CRON_SECRET=<token-aleatorio-32-bytes>

# ─── Opcional ────────────────────────────────────────────────────
# Contraseña inicial del admin del seed (default: nexai2025).
# ADMIN_SEED_PASSWORD=
