# ─────────────────────────────────────────────
# Base de datos NUEVA del CRM (Postgres)
# ─────────────────────────────────────────────
DATABASE_URL="postgresql://USER:PASSWORD@HOST:PORT/crm"

# ─────────────────────────────────────────────
# Base de datos EXISTENTE de n8n (solo se usa la tabla ESTATUS)
# ─────────────────────────────────────────────
N8N_DATABASE_URL="postgresql://USER:PASSWORD@HOST:PORT/postgres"

# ─────────────────────────────────────────────
# NextAuth v5 (Auth.js)
# Genera el secreto con:  openssl rand -base64 32   (o `npx auth secret`)
# ─────────────────────────────────────────────
AUTH_SECRET="cambia-esto-por-un-secreto-de-32-bytes"
NEXTAUTH_SECRET="cambia-esto-por-un-secreto-de-32-bytes"
AUTH_TRUST_HOST="true"
NEXTAUTH_URL="https://postgres-nexcrm.d6cr6o.easypanel.host"

# URL pública para los snippets de n8n (runtime; opcional, default = NEXTAUTH_URL)
APP_URL="https://postgres-nexcrm.d6cr6o.easypanel.host"

# ─────────────────────────────────────────────
# Opcionales (recomendadas para producción)
# ─────────────────────────────────────────────
# Si se define, POST /api/messages exige el header:
#   Authorization: Bearer <MESSAGES_INGEST_TOKEN>   (o  x-api-key: <token>)
# Protege el endpoint público de inyección de mensajes falsos.
MESSAGES_INGEST_TOKEN=""

# Contraseña inicial del admin del seed (si se omite, usa 'nexai2025').
ADMIN_SEED_PASSWORD=""
